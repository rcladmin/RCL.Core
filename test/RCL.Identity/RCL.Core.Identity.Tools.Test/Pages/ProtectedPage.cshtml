@page
@model ProtectedPageModel
@{
    ViewData["Title"] = "Protected page";
}

<div class="card shadow rounded mt-2 mb-5 ">
    <div class="card-header">
        <h3>@ViewData["Title"]</h3>
    </div>
    <div class="card-body">
        <div><strong>Given Name</strong></div>
        <div>@Model?.UserData?.GivenName</div>
        <div><strong>Surname</strong></div>
        <div>@Model?.UserData?.SurName</div>
        <div><strong>Display Name</strong></div>
        <div>@Model?.UserData?.DisplayName</div>
        <div><strong>Email</strong></div>
        <div>@Model?.UserData?.Email</div>
        <div><strong>Country</strong></div>
        <div>@Model?.UserData?.Country</div>
        <div><strong>Object Id</strong></div>
        <div>@Model?.UserData?.ObjectId</div>
    </div>
</div>
