@page
@model RCL.Core.Identity.Proofing.UI.Pages.UserApproval.DeleteModel
@{
    ViewData["Title"] = "Delete Request";
}

<div class="card shadow rounded mt-2 mb-5">
    <div class="card-header">
        <h3><a class="link_click" asp-page="./index"><i class="bi-arrow-left-circle"></i></a> @ViewData["Title"]</h3>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model?.ErrorMessage))
        {
            <div class="alert alert-danger">
                <p>@Model.ErrorMessage</p>
            </div>
        }
        else
        {
            <h4>Do you want to delete this sign-up request ?</h4>
            <div><strong>First Name</strong></div>
            <div>@Html.DisplayFor(model => model.UserData.GivenName)</div>
            <div><strong>Last Name</strong></div>
            <div>@Html.DisplayFor(model => model.UserData.SurName)</div>
            <div><strong>Email</strong></div>
            <div>@Html.DisplayFor(model => model.UserData.Email)</div>
        }
    </div>
    <div class="card-footer">
        <form method="post" id="frm_submit" asp-route-id="@Model?.UserData.Id">
            <div class="form-group">
                <input type="submit" value="Delete" class="btn btn-danger link_click" /> <a asp-page="./Index" class="btn btn-secondary link_click">Cancel</a>
            </div>
        </form>
    </div>
</div>


