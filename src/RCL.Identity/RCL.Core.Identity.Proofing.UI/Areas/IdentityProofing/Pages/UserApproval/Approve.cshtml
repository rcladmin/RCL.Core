@page
@model RCL.Core.Identity.Proofing.UI.Pages.UserApproval.ApproveModel
@{
    ViewData["Title"] = "Approve Request";
}

<div class="card shadow rounded">
    <div class="card-header">
        <h3><a class="link_click" asp-page="./index"><i class="bi-arrow-left-circle"></i></a> @ViewData["Title"]</h3>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model?.ErrorMessage))
        {
            <div class="alert alert-danger">
                <p>@Model.ErrorMessage</p>
            </div>
        }
        else
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle"></i> Please ensure you have physically verified the identity of the applicant before you approve the request.
            </div>
            <h4>Do you want to approve this request ?</h4>
            @if (!string.IsNullOrEmpty(Model?.UserData?.PhotoUrl))
            {
                <div class="mb-3">
                    <img height="90" src="@Model?.UserData.PhotoUrl">
                </div>
            }
            <div><strong>First Name</strong></div>
            <div>@Html.DisplayFor(model => model.UserData.GivenName)</div>
            <div><strong>Last Name</strong></div>
            <div>@Html.DisplayFor(model => model.UserData.SurName)</div>
            <div><strong>Email</strong></div>
            <div>@Html.DisplayFor(model => model.UserData.Email)</div>
            
            <div class="mt-2">
            <form method="post" id="frm_submit" asp-route-id="@Model?.UserData.Id">
                <div class="form-group">
                    <input type="submit" value="Approve" class="btn btn-primary link_click" /> <a asp-page="./Index" class="btn btn-secondary link_click">Cancel</a>
                </div>
            </form>
            </div>
        }
    </div>
</div>
