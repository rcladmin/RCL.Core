@page
@model RCL.Core.Identity.Proofing.UI.Pages.UserApproval.IndexModel
@{
    ViewData["Title"] = "User Requests";
}

<div class="card shadow rounded mt-2 mb-5">
    <div class="card-header"><h3>@ViewData["Title"]</h3></div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model?.ErrorMessage))
        {
            <div class="alert alert-danger">
                <p>@Model.ErrorMessage</p>
            </div>
        }
        else
        {
            @if (Model?.Users.Count > 0)
            {
                <table class="table">
                    <thead>
                        <tr>
                            <th>First Name</th>
                            <th>Last Name</th>
                            <th>Email</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Users)
                        {
                            <tr>
                                <td>@item.GivenName</td>
                                <td>@item.SurName</td>
                                <td>@item.Email</td>
                                <td>
                                    <div class="dropdown">
                                        <a class="btn btn-secondary dropdown-toggle" href="#" role="button" id="dropdownMenuLink" data-bs-toggle="dropdown" aria-expanded="false">
                                            <i class="bi bi-gear"></i>
                                        </a>

                                        <ul class="dropdown-menu" aria-labelledby="dropdownMenuLink">
                                            <li><a class="dropdown-item link_click" asp-page="./Details" asp-route-id="@item.Id"><i class="bi bi-list-ul"></i> Details</a></li>
                                            <li><a class="dropdown-item link_click" asp-page="./Approve" asp-route-id="@item.Id"><i class="bi bi-check-square"></i> Approve</a></li>
                                            <li><a class="dropdown-item link_click" asp-page="./Delete" asp-route-id="@item.Id"><i class="bi bi-trash"></i> Delete</a></li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p>There are no user User Requests to display.</p>
            }
        }
    </div>
</div>
